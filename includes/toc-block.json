{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "tabai/advanced-toc",
    "version": "1.0.0",
    "title": "Tabai Advanced Table of Contents",
    "category": "design",
    "icon": "list-view",
    "description": "A highly customizable, SEO-friendly Table of Contents block.",
    "supports": {
        "html": false,
        "anchor": true,
        "align": [
            "wide",
            "full"
        ]
    },
    "textdomain": "tabai-advanced-toc",
    "attributes": {
        "title": {
            "type": "string",
            "default": "Table of Contents"
        },
        "showTitle": {
            "type": "boolean",
            "default": true
        },
        "showH2": {
            "type": "boolean",
            "default": true
        },
        "showH3": {
            "type": "boolean",
            "default": true
        },
        "showH4": {
            "type": "boolean",
            "default": true
        },
        "excludedHeadings": {
            "type": "array",
            "default": [],
            "items": {
                "type": "string"
            }
        },
        "skipFirstHeading": {
            "type": "boolean",
            "default": false
        },
        "excludeKeywords": {
            "type": "string",
            "default": ""
        },
        "layout": {
            "type": "string",
            "default": "boxed"
        },
        "smoothScroll": {
            "type": "boolean",
            "default": true
        },
        "highlightActive": {
            "type": "boolean",
            "default": true
        },
        "backToTop": {
            "type": "boolean",
            "default": false
        },
        "floatingMobileBtn": {
            "type": "boolean",
            "default": false
        },
        "enableSchema": {
            "type": "boolean",
            "default": true
        },
        "listStyle": {
            "type": "string",
            "default": "bullets"
        },
        "numberingFormat": {
            "type": "string",
            "default": "1"
        },
        "backgroundColor": {
            "type": "string",
            "default": "#f9f9f9"
        },
        "borderColor": {
            "type": "string",
            "default": "#e0e0e0"
        },
        "textColor": {
            "type": "string",
            "default": "#333333"
        },
        "linkColor": {
            "type": "string",
            "default": "#0073aa"
        }
    },
    "editorScript": "file:./toc-build/index.js",
    "editorStyle": "file:./toc-build/index.css",
    "style": "file:./toc-build/style-index.css"
}
